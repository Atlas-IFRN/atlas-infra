# ============================================================
# Atlas — variáveis de ambiente
# Copie para .env e preencha os valores reais. NUNCA commite o .env.
# ============================================================

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=atlas
POSTGRES_USER=atlas_user
POSTGRES_PASSWORD=

# Redis
REDIS_URL=redis://redis:6379/0

# RabbitMQ
RABBITMQ_DEFAULT_USER=atlas
RABBITMQ_DEFAULT_PASS=
RABBITMQ_URL=amqp://atlas:@rabbitmq:5672/

# Auth Service
AUTH_SERVICE_URL=http://auth-service:8000
INTERNAL_TOKEN=

# JWT
JWT_SECRET_KEY=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# SUAP OAuth2
SUAP_CLIENT_ID=
SUAP_CLIENT_SECRET=
SUAP_REDIRECT_URI=https://atlas.ifrn.edu.br/auth/callback/

# Django
DJANGO_SECRET_KEY=
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=atlas.ifrn.edu.br,localhost

# AI Service
OLLAMA_MODEL=qwen2.5-coder:1.5b
GITHUB_TOKEN=

# Nginx
DOMAIN=atlas.ifrn.edu.br

