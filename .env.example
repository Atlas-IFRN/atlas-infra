# ============================================================
# Atlas — variáveis de ambiente
# Copie para .env e preencha. NUNCA commite o .env real.
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
# O compose monta o DATABASE_URL de cada serviço a partir destes
# valores e injeta o schema via PGOPTIONS (search_path).
POSTGRES_DB=atlas
POSTGRES_USER=atlas_user
POSTGRES_PASSWORD=troque_esta_senha

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── RabbitMQ / Celery ────────────────────────────────────────
RABBITMQ_DEFAULT_USER=atlas
RABBITMQ_DEFAULT_PASS=troque_esta_senha
CELERY_BROKER_URL=amqp://atlas:troque_esta_senha@rabbitmq:5672//
CELERY_RESULT_BACKEND=rpc://

# ── Comunicação interna entre serviços ───────────────────────
AI_SERVICE_URL=http://ai-service:8003
INTERNAL_TOKEN=troque_este_token_interno

# ── JWT ──────────────────────────────────────────────────────
DJANGO_SECRET_KEY=troque_esta_secret_key

# ── Django ───────────────────────────────────────────────────
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=atlas.ifrn.edu.br,localhost,127.0.0.1

# ── SUAP OAuth2 ──────────────────────────────────────────────
SUAP_CLIENT_ID=
SUAP_CLIENT_SECRET=
SUAP_REDIRECT_URI=https://atlas.ifrn.edu.br/auth/callback/
SUAP_AUTHORIZATION_URL=https://suap.ifrn.edu.br/o/authorize/
SUAP_TOKEN_URL=https://suap.ifrn.edu.br/o/token/
SUAP_USER_INFO_URL=https://suap.ifrn.edu.br/api/rh/eu/

# ── AI Service / Ollama ──────────────────────────────────────
OLLAMA_MODEL=qwen2.5-coder:1.5b
GITHUB_TOKEN=

# ── Frontend (Vite) ──────────────────────────────────────────
VITE_API_URL=https://atlas.ifrn.edu.br/api
VITE_ENV_NAME=production
